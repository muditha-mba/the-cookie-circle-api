# ─────────────────────────────────────────────────────────────
# THE COOKIE CIRCLE API — Environment Variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Environment: development | staging | production
APP_ENV=development

# Application
APP_NAME="The Cookie Circle API"
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
# macOS Homebrew PostgreSQL uses your system username — not "postgres".
# Linux/Docker typically uses: postgresql+psycopg://postgres:postgres@localhost:5432/cookie_circle
# macOS Homebrew example:     postgresql+psycopg://YOUR_USERNAME@localhost:5432/cookie_circle_dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cookie_circle_dev

# CORS (comma-separated origins; staging/production only — development also allows any localhost port)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# Frontend URLs (for email links)
FRONTEND_CLIENT_URL=http://localhost:3000
FRONTEND_ADMIN_URL=http://localhost:3001

# WhatsApp deep link after website checkout (digits only, country code, no +)
WHATSAPP_BUSINESS_PHONE=94713259795

# ── Staging example ───────────────────────────────────────────
# APP_ENV=staging
# DEBUG=false
# JWT_SECRET_KEY=<strong-random-secret>
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/cookie_circle_staging
# CORS_ORIGINS=https://staging.thecookiecircle.lk,https://admin-staging.thecookiecircle.lk
# FRONTEND_CLIENT_URL=https://staging.thecookiecircle.lk
# FRONTEND_ADMIN_URL=https://admin-staging.thecookiecircle.lk

# ── Production example ──────────────────────────────────────────
# APP_ENV=production
# DEBUG=false
# JWT_SECRET_KEY=<strong-random-secret>
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/cookie_circle
# CORS_ORIGINS=https://thecookiecircle.lk,https://admin.thecookiecircle.lk
# FRONTEND_CLIENT_URL=https://thecookiecircle.lk
# FRONTEND_ADMIN_URL=https://admin.thecookiecircle.lk
