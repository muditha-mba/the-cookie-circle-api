# ─────────────────────────────────────────────────────────────
# THE COOKIE CIRCLE API — Environment Variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Environment: development | staging | production
APP_ENV=development

# Application
APP_NAME="The Cookie Circle API"
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cookie_circle

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Staging example ───────────────────────────────────────────
# APP_ENV=staging
# DEBUG=false
# LOG_LEVEL=INFO
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/cookie_circle_staging
# CORS_ORIGINS=https://staging.thecookiecircle.lk,https://admin-staging.thecookiecircle.lk

# ── Production example ──────────────────────────────────────────
# APP_ENV=production
# DEBUG=false
# LOG_LEVEL=WARNING
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/cookie_circle
# CORS_ORIGINS=https://thecookiecircle.lk,https://admin.thecookiecircle.lk
