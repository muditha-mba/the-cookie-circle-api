# ─────────────────────────────────────────────────────────────
# THE COOKIE CIRCLE API — Environment Variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Environment: development | staging | production
APP_ENV=development

# Application
APP_NAME="The Cookie Circle API"
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
# macOS Homebrew PostgreSQL uses your system username — not "postgres".
# Linux/Docker typically uses: postgresql+psycopg://postgres:postgres@localhost:5432/cookie_circle
# macOS Homebrew example:     postgresql+psycopg://YOUR_USERNAME@localhost:5432/cookie_circle_dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cookie_circle_dev

# CORS (comma-separated origins; staging/production only — development also allows any localhost port)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# Frontend URLs (for email links)
FRONTEND_CLIENT_URL=http://localhost:3000
FRONTEND_ADMIN_URL=http://localhost:3001

# Development-only reusable email verification token (APP_ENV=development only).
# Link format: {FRONTEND_CLIENT_URL}/verify-email?token=dev-verify&email=user@example.com
# Set to empty string to disable.
DEV_EMAIL_VERIFICATION_TOKEN=dev-verify

# WhatsApp deep link after website checkout (digits only, country code, no +)
WHATSAPP_BUSINESS_PHONE=94713259795

# Rate limiting
RATE_LIMIT_ENABLED=true
# Set true only behind a trusted reverse proxy that sets X-Forwarded-For
RATE_LIMIT_TRUST_PROXY=false

# Trusted hosts (comma-separated). Used in staging/production.
TRUSTED_HOSTS=localhost,127.0.0.1

# Optional admin API IP allowlist (comma-separated). Leave empty to disable.
ADMIN_ALLOWED_IPS=

# Email delivery: console | resend (recommended) | smtp (legacy)
# Local dev: set EMAIL_PROVIDER=resend + RESEND_API_KEY to send real emails,
# or leave as console when no key is configured.
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=The Cookie Circle <hello@thecookiecircle.lk>
EMAIL_REPLY_TO=hello@thecookiecircle.lk

# Legacy SMTP fallback (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional Cloudflare Turnstile CAPTCHA
TURNSTILE_SECRET_KEY=
CAPTCHA_REQUIRED=false

# ── Staging example ───────────────────────────────────────────
# APP_ENV=staging
# DEBUG=false
# JWT_SECRET_KEY=<strong-random-secret-at-least-32-chars>
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/cookie_circle_staging?sslmode=require
# CORS_ORIGINS=https://staging.thecookiecircle.lk,https://admin-staging.thecookiecircle.lk
# FRONTEND_CLIENT_URL=https://staging.thecookiecircle.lk
# FRONTEND_ADMIN_URL=https://admin-staging.thecookiecircle.lk
# TRUSTED_HOSTS=api-staging.thecookiecircle.lk
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=The Cookie Circle <hello@thecookiecircle.lk>
# EMAIL_REPLY_TO=hello@thecookiecircle.lk
# Social media links are managed in Admin → Business Settings → Social Media (stored in DB).

# ── Production example ──────────────────────────────────────────
# APP_ENV=production
# DEBUG=false
# JWT_SECRET_KEY=<strong-random-secret-at-least-32-chars>
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/cookie_circle?sslmode=require
# CORS_ORIGINS=https://thecookiecircle.lk,https://admin.thecookiecircle.lk
# FRONTEND_CLIENT_URL=https://thecookiecircle.lk
# FRONTEND_ADMIN_URL=https://admin.thecookiecircle.lk
# TRUSTED_HOSTS=api.thecookiecircle.lk
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=The Cookie Circle <hello@thecookiecircle.lk>
# EMAIL_REPLY_TO=hello@thecookiecircle.lk
# RATE_LIMIT_TRUST_PROXY=true
# ADMIN_ALLOWED_IPS=203.0.113.10,203.0.113.11
# TURNSTILE_SECRET_KEY=<cloudflare-turnstile-secret>
# CAPTCHA_REQUIRED=true
